# Copy to .env.local and fill in. .env.local is gitignored.
# Supabase — https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-public-key

# Face-tracing dots service (MediaPipe / FastAPI, deployed on Railway).
# Powers the landmark overlay on the scanning screen. If unset, generic fallback dots are used.
EXPO_PUBLIC_FACE_DETECT_URL=https://YOUR-SERVICE.up.railway.app

# RevenueCat — https://app.revenuecat.com → Project → API Keys → App-specific public keys
# iOS key starts with appl_ , Android key starts with goog_
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_IOS_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_ANDROID_KEY

# Sentry — https://sentry.io → Settings → Projects → (project) → Client Keys (DSN)
# The DSN is public-safe (it can only send events in, not read data out).
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/YOUR_PROJECT_ID

# PostHog — https://us.posthog.com → Settings → Project → Project API Key (starts phc_)
# Public-safe (write-only ingestion key), same as your frontend snippet.
EXPO_PUBLIC_POSTHOG_KEY=phc_YOUR_PROJECT_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS — do NOT put these in .env.local. EXPO_PUBLIC_* vars are
# inlined into the app bundle and are extractable, so a secret there is NOT secret.
# Set these on the Supabase Edge Functions instead:
#   supabase secrets set FACECHECK_API_TOKEN=... FACECHECK_DEMO=false
#
# FACECHECK_API_TOKEN  FaceCheck.id API token (used by the face-search function)
# FACECHECK_DEMO       "true" = free demo/inaccurate results; "false" in production
#
# SENTRY_AUTH_TOKEN    Sentry → Settings → Auth Tokens (starts sntrys_). Used ONLY
#                      at build time to upload source maps. Set it as an EAS secret,
#                      not here:  eas secret:create --scope project \
#                                   --name SENTRY_AUTH_TOKEN --value sntrys_...
# ─────────────────────────────────────────────────────────────────────────────
